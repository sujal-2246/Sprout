PORT=4000

# Postgres connection
PGHOST=localhost
PGPORT=5432
PGDATABASE=sprout
PGUSER=postgres
PGPASSWORD=postgres

# Set to "true" to bypass Postgres entirely and serve the hardcoded
# in-memory dataset from src/data/mockProducts.js. Useful for building the
# frontend before the database layer is fully wired up.
USE_MOCK_DB=true
